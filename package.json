{
  "name": "ssassplayer",
  "version": "0.1.2",
  "description": "Un reproductor de video/audio modular y extensible con sistema de plugins",
  "private": false,
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/player.css"
  },
  "scripts": {
    "build:js": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean",
    "build:css": "postcss src/styles/index.css -o dist/player.css",
    "build": "npm run build:js && npm run build:css",
    "prepublishOnly": "npm run build",
    "watch:js": "tsup src/index.ts --watch",
    "watch:css": "postcss src/styles/index.css -o dist/player.css --watch",
    "dev": "bun ./bun.ts",
    "test": "echo \"No tests yet\"",
    "lint": "echo \"No linter configured yet\""
  },
  "keywords": [
    "video",
    "audio",
    "player",
    "media",
    "hls",
    "dash",
    "thumbnails",
    "typescript",
    "plugins",
    "modular",
    "framework-agnostic"
  ],
  "author": "Agnostic Player Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nglmercer/ssassplayer.git"
  },
  "bugs": {
    "url": "https://github.com/nglmercer/ssassplayer/issues"
  },
  "homepage": "https://github.com/nglmercer/ssassplayer#readme",
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "cssnano": "^7.1.5",
    "hls.js": "^1.6.15",
    "postcss": "^8.5.9",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "postcss-nesting": "^14.0.0",
    "preact": "^10.29.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "hls.js": "^1.4.0"
  },
  "peerDependenciesMeta": {
    "hls.js": {
      "optional": true
    }
  },
  "dependencies": {
    "assjs": "^0.1.4"
  }
}
